# =============================================================================
# RAG Configuration (Example)
# =============================================================================

# Retrieval parameters
retrieval:
  # Legacy fallback for older config layout (ignored when cosmos.sources is used)
  k_fulltext: 10
  k_diverse: 80       # 0 = disabled; >0 = select this many diverse chunks via log-det
  eta: 0.0            # Gram matrix regularization
  rescale_power: 5.0  # Query-similarity rescale power
  cache_size: 2000

# Semantic ranker (reranking after diversity selection)
ranker:
  use_ranker: false
  k_ranker: 40
  region: ""
  account_name: ""
  read_token_from_path: false
  access_token_path: "access_token.txt"
  tenant_id: "" # this is needed when read_token_from_path = false
  token_scope: "" # this is needed when read_token_from_path = false
  register_account_path: "" # this is needed when read_token_from_path = false
  url_suffix: ""
  batch_size: 64
  max_retries: 10

# Pipeline parameters
pipeline:
  max_sub_questions: 5
  subq_fanout_cap: 3
  subq_max_concurrency: 2
  rounds: 5
  preliminary_prefix: ""
  subquery_prefix: ""
  dataset_description: ""

# Execution parameters
execution:
  max_questions: null  # null = process all questions
  max_workers: 1

# Paths (relative to working directory)
paths:
  questions_path: ""
  output_root: ""

# Azure OpenAI / LLM settings
llm:
  llm_endpoint: ""
  api_version: "2024-05-01-preview"
  llm_model: "model-router"
  temperature: 0.0
  max_completion_tokens: 4096
  max_retries: 2
  premium_max_concurrency: 4
  prompt_cache_size: 2048
  use_rbac_auth: true
  token_scope: ""
  llm_api_key: ""
  tenant_id: ""

# Local LLM fallback settings (used for sub-tasks when use_local_fallback_for_subtasks is true)
local_llm:
  local_fallback_endpoint: "http://localhost:11434/api/generate"
  local_fallback_model: ""
  use_local_fallback_for_subtasks: true
  local_max_concurrency: 8

# Embedding settings
embedding:
  embed_endpoint: ""
  api_version: "2024-05-01-preview"
  api_format: "openai"
  embed_model: ""
  embed_dimensions: 1024
  embed_cache_size: 4096
  use_rbac_auth: true
  token_scope: ""
  embed_api_key: ""

# Cosmos DB settings
cosmos:
  uri: ""
  key: ""
  database_name: "divdet"
  use_rbac_auth: true
  tenant_id: ""

  # Upload settings used by cosmos_db_upload.py
  cosmos_account_name: ""
  cosmos_resource_group: ""
  azure_subscription_id: ""
  concurrent_batches: 4
  embedding_batch_size: 100

  # Throughput settings for new containers (used when dedicated throughput is required)
  throughput_mode: "autoscale"   # "autoscale" or "manual"
  throughput_value: 1000         # max RU/s for autoscale, fixed RU/s for manual

  vector_embedding_policy_json: |
    {
      "vectorEmbeddings": [
        {
          "path": "/e",
          "dataType": "float32",
          "dimensions": 1024,
          "distanceFunction": "cosine"
        }
      ]
    }

  # Configure each source/container independently
  # Retrieval in agentic_retriever.py is derived from this `sources` list.
  sources:
    - id: "source_1"
      container_name: "container_1"
      partition_key_path: "/pk"
      embedding_field: "e"
      documents_root: ""
      embedding_text_fields:
        - title
        - summary
        - content
      retrieval:
        vector_k: 10
        fulltext_k: 10
        fulltext_fields:
          - title
      indexing_policy_json: |
        {
          "indexingMode": "consistent",
          "automatic": true,
          "includedPaths": [
            { "path": "/*" }
          ],
          "excludedPaths": [
            { "path": "/\"_etag\"/?" },
            { "path": "/e/*" }
          ],
          "fullTextIndexes": [
            { "path": "/title" }
          ],
          "vectorIndexes": [
            {
              "path": "/e",
              "type": "diskANN",
              "quantizationByteSize": 192,
              "indexingSearchListSize": 100
            }
          ]
        }
      full_text_policy_json: |
        {
          "defaultLanguage": "en-US",
          "fullTextPaths": [
            { "path": "/title", "language": "en-US" }
          ]
        }

    - id: "source_2"
      container_name: "container_2"
      partition_key_path: "/pk"
      embedding_field: "e"
      documents_root: ""
      embedding_text_fields:
        - text
      retrieval:
        vector_k: 25
        fulltext_k: 0
        fulltext_fields: []
      indexing_policy_json: |
        {
          "indexingMode": "consistent",
          "automatic": true,
          "includedPaths": [
            { "path": "/*" }
          ],
          "excludedPaths": [
            { "path": "/\"_etag\"/?" },
            { "path": "/e/*" }
          ],
          "fullTextIndexes": [
            { "path": "/text" }
          ],
          "vectorIndexes": [
            {
              "path": "/e",
              "type": "diskANN",
              "quantizationByteSize": 192,
              "indexingSearchListSize": 100
            }
          ]
        }
      full_text_policy_json: |
        {
          "defaultLanguage": "en-US",
          "fullTextPaths": [
            { "path": "/text", "language": "en-US" }
          ]
        }
